# Stripe Configuration
# Get these from your Stripe Dashboard: https://dashboard.stripe.com/apikeys
# Hosted Checkout only uses the server key below (no publishable key in the frontend).

# Server-side (Vercel env — never commit real values)
STRIPE_SECRET_KEY=sk_live_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Public site URL for Stripe success/cancel redirects (production: https://your-domain.com)
# SITE_URL=https://driversefoundation.com

# Rate limiting (Upstash Redis — https://console.upstash.com). Omit in local dev to disable limits.
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxx
# Optional override (default 15): max checkout POSTs per IP per minute
# RATE_LIMIT_CHECKOUT_PER_MINUTE=15
