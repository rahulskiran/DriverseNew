# Stripe Configuration
# Get these from your Stripe Dashboard: https://dashboard.stripe.com/apikeys

# Publishable key (client-side, starts with pk_live_ or pk_test_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here

# For production builds (backend - use in your server environment, NOT in client-side code)
STRIPE_SECRET_KEY=sk_live_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# For serverless function (Netlify/Vercel)
# NETLIFY_STRIPE_SECRET_KEY=sk_test_your_secret_key_here
