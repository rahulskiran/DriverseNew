# =============================================================================
# Stripe configuration (server-only — NEVER commit real values)
# =============================================================================
# Get these from your Stripe Dashboard: https://dashboard.stripe.com/apikeys
# Hosted Checkout only uses the secret key on the server (no publishable key in
# the frontend).
STRIPE_SECRET_KEY=sk_live_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Public site URL for Stripe success/cancel redirects AND CORS allow-list.
# REQUIRED in production and preview — without it CORS rejects all browser callers.
SITE_URL=https://driversefoundation.com

# =============================================================================
# Upstash Redis — currently NOT USED
# =============================================================================
# Rate limiting and webhook idempotency are temporarily disabled. No Upstash
# configuration is required. To re-enable, add a client back in
# api/lib/rate-limit.js and api/lib/idempotency.js and set:
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxx
